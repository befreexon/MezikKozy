<script>
let state = {};

function roll(sides = 6) {
  return Math.floor(Math.random() * sides) + 1;
}

function startGame() {
  const names = [
    document.getElementById('name1').value.trim() || 'Hráč 1',
    document.getElementById('name2').value.trim() || 'Hráč 2',
    document.getElementById('name3').value.trim(),
    document.getElementById('name4').value.trim(),
  ].filter(n => n.length > 0).slice(0, 4);

  if (names.length < 2) { alert('Zadejte alespoň 2 hráče!'); return; }

  state = {
    players: names.map(n => ({ name: n, money: 100, eliminated: false })),
    current: 0,
    bank: 0,
    phase: 'new-round',
    firstRoll: null,
    selectedBet: null,
    lastResult: null,
  };

  document.getElementById('setup-screen').classList.add('hidden');
  renderLog('system', '🎲 Hra začíná! Každý hráč má 100 Kč.');

  // Collect ante from ALL players at game start
  collectAnteFromAll('Počáteční vklad do banku');

  checkEliminations();
  renderAll();
}

// Collect 10 Kč ante from every active player at once
function collectAnteFromAll(reason) {
  const active = state.players.filter(p => !p.eliminated);
  let total = 0;
  active.forEach(p => {
    const ante = Math.min(10, p.money);
    if (ante > 0) {
      p.money -= ante;
      state.bank += ante;
      total += ante;
    }
  });
  if (total > 0) {
    const names = active.map(p => p.name).join(', ');
    renderLog('system', `💰 ${reason}: každý vložil 10 Kč do banku. (${names})`);
  }
}

function renderAll() {
  renderPlayers();
  renderDice();
  renderControls();
}

function renderPlayers() {
  const bar = document.getElementById('players-bar');
  const active = state.players.filter(p => !p.eliminated);
  
  // Bank in middle always
  const bankHTML = `<div class="bank-display">
    <div class="label">Banka</div>
    <div class="bank-amount">${state.bank} Kč</div>
  </div>`;

  if (active.length === 2) {
    bar.style.gridTemplateColumns = '1fr auto 1fr';
    bar.innerHTML = playerCardHTML(state.players[0]) + bankHTML + playerCardHTML(state.players[1]);
  } else {
    const all = state.players.map(p => playerCardHTML(p)).join('');
    bar.style.gridTemplateColumns = `repeat(${state.players.length}, 1fr) auto`;
    bar.innerHTML = all + bankHTML;
  }
}

function playerCardHTML(p) {
  const idx = state.players.indexOf(p);
  const isActive = idx === state.current && !p.eliminated;
  return `<div class="player-card ${isActive ? 'active' : ''} ${p.eliminated ? 'eliminated' : ''}">
    ${isActive ? '<div class="active-indicator"></div>' : ''}
    <h3>${p.name}</h3>
    <div class="player-money">${p.money} <span>Kč</span></div>
    ${p.eliminated ? '<div style="font-size:0.75rem;color:#e06060;margin-top:4px;">VYŘAZEN</div>' : ''}
  </div>`;
}

function renderDice() {
  const d1 = document.getElementById('d1');
  const d2 = document.getElementById('d2');
  const d3 = document.getElementById('d3');
  const rangeEl = document.getElementById('range-display');
  const bonusWrapper = document.getElementById('bonus-die-wrapper');
  const dBonus = document.getElementById('d-bonus');

  if (!state.firstRoll) {
    setDie(d1, null); setDie(d2, null); setDie(d3, null);
    rangeEl.classList.add('hidden');
    bonusWrapper.style.display = 'none';
    d1.className = 'die empty'; d2.className = 'die empty'; d3.className = 'die empty';
    return;
  }

  const sorted = [...state.firstRoll].sort((a,b) => a - b);
  const [lo, mid, hi] = sorted;

  setDie(d1, lo);
  setDie(d2, mid);
  setDie(d3, hi);

  d1.className = 'die highlight-min';
  d3.className = 'die highlight-max';
  d2.className = 'die';

  rangeEl.classList.remove('hidden');
  rangeEl.textContent = `Rozsah: ${lo} – ${hi}  •  Musíte hodit mezi ${lo} a ${hi}`;

  if (state.bonusRoll !== undefined) {
    bonusWrapper.style.display = 'flex';
    setDie(dBonus, state.bonusRoll);
    const inBetween = state.bonusRoll > lo && state.bonusRoll < hi;
    dBonus.className = 'die ' + (inBetween ? 'highlight-between' : 'highlight-miss');
  } else if (state.phase === 'betting' || state.phase === 'bonus-rolled') {
    bonusWrapper.style.display = 'flex';
    setDie(dBonus, null);
    dBonus.className = 'die empty';
  } else {
    bonusWrapper.style.display = 'none';
  }
}

function setDie(el, val) {
  el.textContent = val === null ? '?' : val;
}

function renderControls() {
  const p = state.players[state.current];
  const turnText = document.getElementById('turn-text');
  const phaseTitle = document.getElementById('phase-title');
  const area = document.getElementById('control-area');

  turnText.textContent = `Na tahu: ${p.name} (${p.money} Kč)`;

  if (state.phase === 'new-round') {
    phaseTitle.textContent = 'Hoďte třemi kostkami';
    area.innerHTML = `<button class="action-btn primary" onclick="doFirstRoll()">🎲 Hodit třemi kostkami</button>`;
  }

  else if (state.phase === 'rolled') {
    const sorted = [...state.firstRoll].sort((a,b) => a - b);
    const lo = sorted[0], hi = sorted[2];
    if (lo === hi || hi - lo === 1) {
      phaseTitle.textContent = 'Žádný platný rozsah – kolo přeskočeno';
      area.innerHTML = `<p class="skip-info">Rozsah je příliš malý, nelze hrát. Přejděte na dalšího hráče.</p>
        <br><button class="action-btn primary" onclick="nextPlayer()">Další hráč →</button>`;
    } else {
      phaseTitle.textContent = 'Vsaďte si – nebo přeskočte';
      area.innerHTML = buildBetUI(p);
    }
  }

  else if (state.phase === 'betting') {
    phaseTitle.textContent = `Vsadili jste ${state.selectedBet} Kč – hoďte!`;
    area.innerHTML = `<button class="action-btn primary" onclick="doBonusRoll()">🎲 Hodit kostkou</button>`;
  }

  else if (state.phase === 'result') {
    phaseTitle.textContent = state.lastResult === 'win' ? '✨ Výhra!' : '💸 Prohra!';
    area.innerHTML = `<button class="action-btn primary" onclick="nextPlayer()">Další hráč →</button>`;
  }
}

function buildBetUI(p) {
  const maxBet = p.money;
  const bets = [10, 20, 30, 50].filter(b => b <= maxBet);
  let html = `<div class="bet-row">`;
  bets.forEach(b => {
    html += `<button class="bet-btn ${state.selectedBet === b ? 'selected' : ''}" onclick="selectBet(${b})">${b} Kč</button>`;
  });
  if (maxBet > 0) {
    html += `<button class="bet-btn ${state.selectedBet === maxBet ? 'selected' : ''}" onclick="selectBet(${maxBet})">All-in (${maxBet} Kč)</button>`;
  }
  html += `</div>`;

  html += `<div class="btn-group">
    <button class="action-btn primary" onclick="confirmBet()" ${!state.selectedBet ? 'disabled' : ''}>Vsadit a hrát</button>
    <button class="action-btn secondary" onclick="skipBonusRoll()">Přeskočit</button>
  </div>`;
  return html;
}

function selectBet(amount) {
  state.selectedBet = amount;
  renderControls();
}

function doFirstRoll() {
  const dice = [roll(), roll(), roll()];
  state.firstRoll = dice;
  state.bonusRoll = undefined;
  state.phase = 'rolled';

  // Animate dice
  ['d1','d2','d3'].forEach(id => {
    document.getElementById(id).classList.add('rolling');
    setTimeout(() => document.getElementById(id).classList.remove('rolling'), 500);
  });

  const sorted = [...dice].sort((a,b)=>a-b);
  renderLog('info', `${state.players[state.current].name} hodil: ${sorted.join(', ')}`);

  setTimeout(() => renderAll(), 150);
}

function confirmBet() {
  if (!state.selectedBet) return;
  state.phase = 'betting';
  renderAll();
}

function skipBonusRoll() {
  renderLog('info', `${state.players[state.current].name} přeskočil bonusový hod.`);
  nextPlayer();
}

function doBonusRoll() {
  const bonus = roll();
  state.bonusRoll = bonus;
  const sorted = [...state.firstRoll].sort((a,b)=>a-b);
  const lo = sorted[0], hi = sorted[2];
  const inBetween = bonus > lo && bonus < hi;

  const bonusEl = document.getElementById('d-bonus');
  bonusEl.classList.add('rolling');
  setTimeout(() => bonusEl.classList.remove('rolling'), 500);

  const p = state.players[state.current];
  const bet = state.selectedBet;

  if (inBetween) {
    // Win – take from bank
    const won = Math.min(bet, state.bank);
    p.money += won;
    state.bank -= won;
    state.lastResult = 'win';
    renderLog('win', `🏆 ${p.name} hodil ${bonus} (mezi ${lo} a ${hi}). Vyhrál ${won} Kč!`);

    // If bank is now empty, collect ante from all before next turn
    if (state.bank === 0) {
      checkEliminations();
      const alive = state.players.filter(q => !q.eliminated);
      if (alive.length > 1) {
        renderLog('system', '🏦 Banka je prázdná!');
        collectAnteFromAll('Nový vklad do banku');
      }
    }
  } else {
    // Loss
    const lost = Math.min(bet, p.money);
    p.money -= lost;
    state.bank += lost;
    state.lastResult = 'loss';
    renderLog('loss', `💸 ${p.name} hodil ${bonus} (mimo ${lo}–${hi}). Prohrál ${lost} Kč.`);
  }

  state.phase = 'result';
  checkEliminations();

  setTimeout(() => renderAll(), 200);
}

function checkEliminations() {
  state.players.forEach(p => {
    if (!p.eliminated && p.money <= 0) {
      p.eliminated = true;
      p.money = 0;
      renderLog('loss', `💀 ${p.name} nemá žádné peníze a je vyřazen!`);
    }
  });
  const alive = state.players.filter(p => !p.eliminated);
  if (alive.length === 1) {
    endGame(alive[0]);
  }
}

function endGame(winner) {
  document.getElementById('gameover-screen').classList.remove('hidden');
  document.getElementById('winner-title').textContent = `🏆 ${winner.name} vyhrál!`;
  document.getElementById('winner-text').textContent = `Gratulujeme! ${winner.name} přežil a odnáší si ${winner.money + state.bank} Kč.`;
}

function nextPlayer() {
  // Move to next non-eliminated player
  let next = (state.current + 1) % state.players.length;
  let tries = 0;
  while (state.players[next].eliminated && tries < state.players.length) {
    next = (next + 1) % state.players.length;
    tries++;
  }

  state.current = next;
  state.firstRoll = null;
  state.bonusRoll = undefined;
  state.selectedBet = null;
  state.lastResult = null;
  state.phase = 'new-round';

  checkEliminations();
  renderAll();
}

function renderLog(type, msg) {
  const log = document.getElementById('log');
  const entry = document.createElement('div');
  entry.className = `log-entry ${type}`;
  entry.textContent = msg;
  log.insertBefore(entry, log.firstChild);
  // Keep max 40 entries
  while (log.children.length > 40) log.removeChild(log.lastChild);
}
</script>

